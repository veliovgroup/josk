# Internal docs (README.md is force-included by npm regardless)
*.md
AGENTS.md

# Editor / OS junk
.DS_Store
.claude/
.cursor/
.cursorignore

# Lint / format configs (build-time only)
.eslintcache
.eslintrc

# CI / dev infra
.github
scripts/

# Meteor-only artifacts
.meteor
.meteorignore
.npm
.versions
package.js

# Build-time TypeScript configs and temp output
tsconfig.json
tsconfig.types.json
.types-tmp/

# CJS declaration source (compiled into index.d.cts at publish time)
index.cts

# Tests and coverage
test/
jest.config.mjs
/coverage

# Documentation site sources (README.md ships separately)
docs/

# Adapter authoring template (kept in repo for reference, not for consumers)
adapters/blank-example.js
adapters/blank-example.d.ts

# Branding / assets
cover.jpg
cover.png

# Build artifacts / logs / lockfiles that should never leak into a publish
node_modules
package-lock.json
*.tgz
*.log
npm-debug.log*
