{
  "name": "josk",
  "version": "6.1.0",
  "description": "Tasks/CRON scheduler and manager for horizontally scaled multi-server applications. Supports Redis, MongoDB, PostgreSQL adapters.",
  "main": "index.js",
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      }
    }
  },
  "scripts": {
    "build:types": "rm -rf ./.types-tmp && tsc -p tsconfig.json --outDir ./.types-tmp && node scripts/strip-internal.mjs ./.types-tmp/index.d.ts ./.types-tmp/index.d.cts ./.types-tmp/adapters/redis.d.ts ./.types-tmp/adapters/mongo.d.ts ./.types-tmp/adapters/postgres.d.ts ./.types-tmp/adapters/blank-example.d.ts && cp ./.types-tmp/index.d.ts ./index.d.ts && cp ./.types-tmp/index.d.cts ./index.d.cts && cp ./.types-tmp/adapters/*.d.ts ./adapters/ && rm -rf ./.types-tmp",
    "prepublishOnly": "rollup index.js --file index.cjs --format cjs --external node:crypto && npm run build:types",
    "test": "mocha ./test/npm.js && npm run test:jest && npm run test:types",
    "test:adapter-guards": "mocha ./test/adapter-guards.js",
    "test:jest": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:jest:core": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand test/jest/core.test.js",
    "test:jest:adapters": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand test/jest/adapters.test.js",
    "test:bun": "bun test ./test/jest/",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --coverage",
    "test:types": "tsc -p ./tsconfig.types.json",
    "test:redis": "mocha ./test/npm-redis.js",
    "test:mongo": "mocha ./test/npm-mongo.js",
    "test:postgres": "mocha ./test/npm-postgres.js"
  },
  "keywords": [
    "agenda",
    "agent",
    "cluster",
    "CRON",
    "highload",
    "high load",
    "horizontal scaling",
    "job",
    "jobs",
    "manager",
    "mongo",
    "mongodb",
    "redis",
    "redisdb",
    "schedule",
    "scheduler",
    "servers",
    "task",
    "task manager",
    "task scheduler",
    "tasks"
  ],
  "tags": [
    "agenda",
    "agent",
    "cluster",
    "CRON",
    "highload",
    "high load",
    "horizontal scaling",
    "job",
    "jobs",
    "manager",
    "mongo",
    "mongodb",
    "redis",
    "redisdb",
    "schedule",
    "scheduler",
    "servers",
    "task",
    "task manager",
    "task scheduler",
    "tasks"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/veliovgroup/josk.git"
  },
  "bugs": {
    "url": "https://github.com/veliovgroup/josk/issues"
  },
  "homepage": "https://github.com/veliovgroup/josk",
  "author": "dr.dimitru (https://veliovgroup.com)",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "cron-parser": "^5.5.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.5",
    "mongodb": "^7.2.0",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3"
  }
}
